{
    "name": "gearmagicru/cms-start-edition",
    "description": "GM CMS: Start edition",
    "keywords": ["gm", "cms", "edition"],
    "homepage": "https://gearmagic.ru",
    "type": "project",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Anton Tivonenko",
            "email": "anton.tivonenko@gmail.com",
            "homepage": "https://gearmagic.ru"
        }
    ],
    "require": {
        "php": ">=8.2",
        "gearmagicru/gm-composer-plugin": "*",
        "gearmagicru/gm-skeleton": "1.*",
        "gearmagicru/gm-site": "1.*",
        "gearmagicru/gm-panel": "1.*",
        "gearmagicru/gm-panel-assets": "1.*",
        "gearmagicru/gm-theme-green": "*",
        "gearmagicru/gm-theme-impact": "*",
        "gearmagicru/gm-setup": "1.*",
        "gearmagicru/gm-wd-article": "*"
    },
    "config": {
        "allow-plugins": {
            "gearmagicru/gm-composer-plugin": true
        }
    },
    "scripts": {
        "app-install": "Gm\\ComposerPlugin\\Scripts::appInstall"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
