{
    "name": "gearmagicru/cms-start-edition",
    "description": "GM CMS: Start edition",
    "keywords": ["gm", "cms", "edition"],
    "homepage": "https://gearmagic.ru",
    "type": "project",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Anton Tivonenko",
            "email": "anton.tivonenko@gmail.com",
            "homepage": "https://gearmagic.ru"
        }
    ],
    "require": {
        "php": ">=8.2",
        "gearmagicru/gm-composer-plugin": "*",
        "gearmagicru/gm-skeleton": "^1.0",
        "gearmagicru/gm-panel": "^1.0",
        "gearmagicru/gm-panel-assets": "^1.0",
        "gearmagicru/gm-theme-green": "*",
        "gearmagicru/gm-setup": "^1.0",
        "gearmagicru/gm-wd-article": "*"
    },
    "config": {
        "allow-plugins": {
            "gearmagicru/gm-composer-plugin": true
        }
    },
    "extra": {
        "gm": {
            "replace": [
                ["/gm.setup/queries/tables.php", "/modules/gm//gm.setup/queries/tables.php"]
            ]
        }
    },
    "scripts": {
        "post-package-install": "Gm\\ComposerPlugin\\Events::postPackageInstall"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
